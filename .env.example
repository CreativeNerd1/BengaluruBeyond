# Environment Configuration
# Copy this to .env.local for development or .env.production for deployment

# API URL - REQUIRED
# Development: http://localhost:5077/api
# Production: Your deployed backend URL (e.g., https://vrudhicabs-api.railway.app/api)
VITE_API_URL=http://localhost:5077/api

# Application Name
VITE_APP_NAME=VrudhiCabs

# Site URL (for SEO and social sharing)
VITE_SITE_URL=https://vrudhicabs.in

# WhatsApp Business Number (without +)
VITE_WHATSAPP_NUMBER=919876543210
